<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/primary"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:scaleType="fitCenter"
            android:contentDescription="Retour"
            android:padding="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- ══════════════════════════════════ -->
            <!-- Section : PROFIL                   -->
            <!-- ══════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PROFIL"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="20dp"
                app:strokeColor="@color/accent"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Nom -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nom"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="12dp" />

                    <!-- Identifiant -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Identifiant"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvProfileIdentifier"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="12dp" />

                    <!-- Contact ID + Statut sur la même ligne -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Contact ID"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.08"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:id="@+id/tvProfileContactId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:paddingVertical="4dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvProfileStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>

                    <!-- Séparateur -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/primary_variant"
                        android:layout_marginVertical="12dp" />

                    <!-- Date connexion -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Connecté depuis"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvProfileCreatedAt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════ -->
            <!-- Section : PASSERELLE HTTP SMS      -->
            <!-- ══════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PASSERELLE HTTP SMS"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Adresse d'accès -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adresse d'accès depuis le PC"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvGatewayAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="12dp" />

                    <!-- Token API -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Token d'authentification (X-Api-Token)"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvApiToken"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:paddingVertical="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyToken"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Copier"
                            android:textSize="12sp"
                            app:strokeColor="@color/accent"
                            android:textColor="@color/accent"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <!-- Port -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Port du serveur"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="2dp" />

                    <EditText
                        android:id="@+id/etServerPort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="8080"
                        android:inputType="number"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:fontFamily="monospace"
                        android:textSize="14sp"
                        android:background="@drawable/input_background"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp"
                        android:layout_marginBottom="16dp"
                        android:singleLine="true"
                        android:maxLines="1" />

                    <!-- Séparateur -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/primary_variant"
                        android:layout_marginBottom="12dp" />

                    <!-- Bouton Start/Stop -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleGateway"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Démarrer la passerelle"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/accent"
                        app:cornerRadius="10dp"
                        android:layout_marginBottom="8dp" />

                    <!-- Bouton Régénérer token -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegenToken"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="Régénérer le token"
                        android:textSize="13sp"
                        app:strokeColor="@color/text_secondary"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════ -->
            <!-- Section : RELAIS WEBHOOK           -->
            <!-- ══════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RELAIS WEBHOOK"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="URL de destination pour les SMS déchiffrés reçus. Laissez vide pour désactiver."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/etWebhookUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="https://votreserveur.com/webhook"
                        android:inputType="textUri"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:background="@drawable/input_background"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp"
                        android:layout_marginBottom="12dp"
                        android:singleLine="true"
                        android:maxLines="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveWebhook"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Enregistrer l'URL"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/accent"
                        app:cornerRadius="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════ -->
            <!-- Section : COMPTE                   -->
            <!-- ══════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COMPTE"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Déconnexion -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogout"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Se déconnecter"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/sos_red"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_lock"
                        app:iconTint="@color/white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sentry Link – Africasys"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
