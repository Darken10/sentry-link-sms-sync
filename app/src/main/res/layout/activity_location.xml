<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/primary"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:scaleType="fitCenter"
            android:contentDescription="Retour"
            android:padding="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/location_title"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

        <!-- Bouton actualiser (icône sync) -->
        <ImageView
            android:id="@+id/btnRefresh"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_sync"
            android:scaleType="fitCenter"
            android:contentDescription="Actualiser"
            android:padding="6dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ═══════════════════════════════════════ -->
            <!-- Carte Position                          -->
            <!-- ═══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- En-tête : titre + badge source -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_location"
                            android:scaleType="fitCenter"
                            app:tint="@color/accent"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Position Actuelle"
                            android:textColor="@color/accent"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <!-- Badge source : GPS, GSM ou inconnu -->
                        <TextView
                            android:id="@+id/tvSourceBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/accent"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/status_badge_active" />
                    </LinearLayout>

                    <!-- Spinner de recherche -->
                    <ProgressBar
                        android:id="@+id/locationProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="visible"
                        android:indeterminateTint="@color/accent"
                        android:layout_marginBottom="8dp" />

                    <!-- Texte de statut -->
                    <TextView
                        android:id="@+id/locationStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/location_searching"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <!-- Coordonnées GPS -->
                    <LinearLayout
                        android:id="@+id/gpsInfoLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:background="@drawable/input_background"
                        android:padding="12dp"
                        android:layout_marginTop="4dp">

                        <!-- Latitude -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="LAT"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1"
                                android:fontFamily="monospace" />

                            <TextView
                                android:id="@+id/latitudeText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:fontFamily="monospace"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Longitude -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="LON"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1"
                                android:fontFamily="monospace" />

                            <TextView
                                android:id="@+id/longitudeText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="--"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:fontFamily="monospace"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Précision + source -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/accuracyText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Précision : --"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/sourceText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GPS"
                                android:textColor="@color/accent"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Heure de mise à jour -->
                    <TextView
                        android:id="@+id/tvLastUpdate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:gravity="end"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════ -->
            <!-- Carte Relais GSM (masquée par défaut)   -->
            <!-- ═══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cellInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- En-tête -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Relais GSM Détectés"
                            android:textColor="@color/accent"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCellCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/cellInfoText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:background="@drawable/input_background"
                        android:padding="10dp"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════ -->
            <!-- Carte Actions                           -->
            <!-- ═══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Bouton envoi manuel -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSendLocation"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/btn_send_location"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:enabled="false"
                        app:backgroundTint="@color/card_location"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_messaging"
                        app:iconTint="@color/white"
                        android:layout_marginBottom="16dp" />

                    <!-- Séparateur -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/primary_variant"
                        android:layout_marginBottom="14dp" />

                    <!-- Toggle envoi automatique périodique -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Envoi automatique"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvPeriodicInterval"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Toutes les 60 min"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchPeriodicLoc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
